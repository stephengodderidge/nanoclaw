# GitHub personal access token for Copilot API access.
# Requires a GitHub Copilot subscription on the account.
# No scopes needed — create a fine-grained PAT with zero permissions at:
#   https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=your_github_token_here

# Model to use for agent sessions (default: claude-opus-4.6)
# MODEL=claude-opus-4.6
